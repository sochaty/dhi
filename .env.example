# Copy to .env and adjust values
# cp .env.example .env

# Model served by Ollama for FIM completions
FIM_MODEL=starcoder2:3b
# Options: starcoder2:3b | qwen2.5-coder:7b | deepseek-coder-v2:16b

# Embedding model (nomic runs locally via Ollama)
EMBED_MODEL=nomic-embed-text

# Max tokens to generate per completion (lower = faster)
FIM_MODEL_MAX_TOKENS=64

# Platform layer (post-9 — leave blank for local-only mode)
JWT_SECRET=changeme
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
REDIS_URL=redis://localhost:6379
STRIPE_SECRET_KEY=
